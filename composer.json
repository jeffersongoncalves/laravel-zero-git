{
    "name": "jeffersongoncalves/laravel-zero-git",
    "description": "Detect the current repository from the git remote: parse SSH/HTTPS remote URLs into host/owner/repo and build a stable slug, used by CLIs that auto-detect their workspace/repo.",
    "keywords": ["laravel-zero", "cli", "git", "remote", "repository", "slug"],
    "homepage": "https://github.com/jeffersongoncalves/laravel-zero-git",
    "license": "MIT",
    "authors": [
        { "name": "Jefferson Goncalves", "email": "jeffersongoncalves@users.noreply.github.com" }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "laravel/pint": "^1.25",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.8|^4.1",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": { "JeffersonGoncalves\\LaravelZero\\Git\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "JeffersonGoncalves\\LaravelZero\\Git\\Tests\\": "tests/" }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "lint": "pint",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse",
        "test:unit": "pest",
        "test": ["@test:unit", "@test:lint"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": { "pestphp/pest-plugin": true }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
